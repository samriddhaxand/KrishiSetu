<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#E0E2DB"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvOrderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 Apr 2026"
                android:textColor="#757575"
                android:textSize="12sp"
                android:drawablePadding="6dp"
                app:drawableStartCompat="@drawable/calender"
                app:drawableTint="#9E9E9E"/>

            <TextView
                android:id="@+id/tvOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="DELIVERED"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/status_badge_delivered"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"/>
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E2DB" android:layout_margin="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgProduct"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/tomatoes"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/OrderCardImageCorners" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tvProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fresh Tomatoes"
                    android:textColor="#1A2E24"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvFarmerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="By Ramesh Kumar"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tvLongTermBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Long Term (3months)"
                    android:textColor="#EF6C00"
                    android:textSize="10sp"
                    android:background="#FFE0B2"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Qty: 5 per kg"
                android:textColor="#1A2E24"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="₹225"
                android:textColor="#1A2E24"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>